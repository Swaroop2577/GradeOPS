# ─────────────────────────────────────────────────────────────────────────────
# GradeOps — Client Environment Variables (Vite)
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# NEVER put secrets here — this is bundled into the frontend.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API ──────────────────────────────────────────────────────────────────────
# In development the Vite proxy (vite.config.js) forwards /api → localhost:5000
# so this is only needed in production builds.
VITE_API_BASE_URL=http://localhost:5000/api

# ─── App meta ─────────────────────────────────────────────────────────────────
VITE_APP_NAME=GradeOps
VITE_APP_VERSION=1.0.0

# ─── Feature flags (Phase 2+) ─────────────────────────────────────────────────
# Set to true once the backend feature is ready
VITE_FEATURE_EXAM_UPLOAD=true
VITE_FEATURE_RUBRIC_BUILDER=true
VITE_FEATURE_PLAGIARISM=true